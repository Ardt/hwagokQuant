#!/bin/sh
# Pre-commit hook: check compilation before committing

# Dashboard (TypeScript type check — fast)
if git diff --cached --name-only | grep -q "^dashboard/"; then
  echo "🔍 Checking dashboard types..."
  cd dashboard
  npx tsc --noEmit
  if [ $? -ne 0 ]; then
    echo "❌ TypeScript errors. Fix before committing."
    exit 1
  fi
  echo "✅ Dashboard types OK"
  cd ..
fi

# Python (syntax check)
PYTHON_FILES=$(git diff --cached --name-only | grep '\.py$')
if [ -n "$PYTHON_FILES" ]; then
  echo "🔍 Checking Python syntax..."
  for f in $PYTHON_FILES; do
    python -c "import ast; ast.parse(open('$f', encoding='utf-8').read())" 2>&1
    if [ $? -ne 0 ]; then
      echo "❌ Syntax error in $f"
      exit 1
    fi
  done
  echo "✅ Python syntax OK"
fi
