#!/bin/sh
# Pre-commit hook: check compilation before committing

# Dashboard (Next.js/TypeScript)
if git diff --cached --name-only | grep -q "^dashboard/"; then
  echo "🔍 Checking dashboard build..."
  cd dashboard
  npx next build --no-lint
  BUILD_EXIT=$?
  cd ..
  if [ $BUILD_EXIT -ne 0 ]; then
    echo "❌ Dashboard build failed. Fix errors before committing."
    exit 1
  fi
  echo "✅ Dashboard build OK"
fi

# Python (syntax check)
PYTHON_FILES=$(git diff --cached --name-only | grep '\.py$')
if [ -n "$PYTHON_FILES" ]; then
  echo "🔍 Checking Python syntax..."
  for f in $PYTHON_FILES; do
    python -c "import ast; ast.parse(open('$f').read())" 2>&1
    if [ $? -ne 0 ]; then
      echo "❌ Syntax error in $f"
      exit 1
    fi
  done
  echo "✅ Python syntax OK"
fi
