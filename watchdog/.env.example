# OCI Instance to monitor
OCI_INSTANCE_ID=ocid1.instance.oc1.ap-seoul-1.xxxx

# Database (same as main project)
Q_DB_URL=postgresql+psycopg2://postgres.xxx:PASS@HOST:5432/postgres?sslmode=require

# Alert threshold (hours without activity = stale)
STALE_HOURS=25

# Notifications (optional, at least one recommended)
SLACK_WEBHOOK=
DISCORD_WEBHOOK=
